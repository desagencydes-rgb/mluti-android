<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f0f0f0">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#555555"
        android:padding="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TP5-P1"
            android:textColor="#ffffff"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:elevation="4dp"
        android:layout_marginTop="4dp">

        <!-- Activity 1 Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activité 1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="#888888"
            android:textColor="#ffffff"/>

        <!-- Input 1 -->
        <EditText
            android:id="@+id/editPositif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Saisir un nombre positif"
            android:inputType="numberDecimal"
            android:layout_margin="8dp"
            android:padding="10dp"
            android:background="@drawable/input_border"/>

        <!-- Input 2 -->
        <EditText
            android:id="@+id/editSigne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Saisir un nombre signé"
            android:inputType="numberDecimal|numberSigned"
            android:layout_margin="8dp"
            android:padding="10dp"
            android:background="@drawable/input_border"/>

        <!-- Operation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="8dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnPlus"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="+"
                android:textSize="18sp"
                android:layout_margin="4dp"
                android:backgroundTint="#888888"/>

            <Button
                android:id="@+id/btnMoins"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="-"
                android:textSize="18sp"
                android:layout_margin="4dp"
                android:backgroundTint="#888888"/>

            <Button
                android:id="@+id/btnMul"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="*"
                android:textSize="18sp"
                android:layout_margin="4dp"
                android:backgroundTint="#888888"/>

            <Button
                android:id="@+id/btnDiv"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="/"
                android:textSize="18sp"
                android:layout_margin="4dp"
                android:backgroundTint="#888888"/>
        </LinearLayout>

        <!-- Result -->
        <TextView
            android:id="@+id/textResultat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Le résultat est : ..."
            android:textSize="16sp"
            android:padding="12dp"/>

    </LinearLayout>

</LinearLayout>
